{
  "name": "@jvrmaia/chatlab",
  "version": "1.1.0",
  "description": "Local development platform for chat agents — workspaces, multi-provider LLMs, feedback corpus.",
  "license": "MIT",
  "author": "João Víctor Rocon Maia",
  "homepage": "https://github.com/jvrmaia/chatlab#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jvrmaia/chatlab.git"
  },
  "bugs": {
    "url": "https://github.com/jvrmaia/chatlab/issues"
  },
  "keywords": [
    "chat-agent",
    "llm",
    "openai",
    "anthropic",
    "ollama",
    "developer-tools",
    "workspaces",
    "feedback-corpus"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "./dist/server/index.js",
  "types": "./dist/server/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "bin": {
    "chatlab": "./dist/server/cli.js"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.ui.json --noEmit",
    "build": "npm run build:server && npm run build:ui",
    "build:server": "tsc -p tsconfig.json",
    "build:ui": "vite build",
    "dev": "tsx watch src/cli.ts",
    "dev:ui": "vite",
    "start": "node dist/server/cli.js",
    "test": "vitest run && vitest run --config vitest.ui.config.ts",
    "test:server": "vitest run",
    "test:ui": "vitest run --config vitest.ui.config.ts",
    "test:watch": "vitest",
    "docs:capture": "playwright test --config=docs/_capture/playwright.config.ts",
    "docs:capture:install": "playwright install chromium",
    "docs:dev": "npm run start --prefix docs-site",
    "docs:build": "npm run build --prefix docs-site"
  },
  "files": [
    "dist",
    "README.md",
    "README.pt-BR.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@duckdb/node-api": "1.5.2-r.1",
    "better-sqlite3": "^11.3.0",
    "express": "^4.21.0",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "multer": "^1.4.5-lts.2",
    "pino": "^10.3.1",
    "react-i18next": "^17.0.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.1.1",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.13",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vite": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
